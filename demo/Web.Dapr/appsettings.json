{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "EasyCore.Dapr": "Information"
    }
  },
  "AllowedHosts": "*",
  "Dapr": {
    "HttpEndpoint": "http://127.0.0.1:3500/",
    "AppId": "easycore-web",
    "DefaultStateStore": "statestore",
    "DefaultPubSub": "pubsub",
    "DefaultSecretStore": "secretstore",
    "WaitForSidecar": false,
    "FailFastIfSidecarUnavailable": false,
    "Timeout": "00:00:30"
  }
}
